# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Hard live-trading guard (I-4 in @architecture.md) ---
# Both LIVE_TRADING=true AND a session-time human "go live" required for real orders.
LIVE_TRADING=false

# --- Kill switch (Section 5 in @design-doc.md) ---
# Monitor polls this every 5s. true → halt all new orders.
KILL_SWITCH=false

# --- LLM providers ---
ANTHROPIC_API_KEY=
# Optional fallback providers (S-02 provider abstraction):
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Exchange (data) — Binance public, no auth needed for OHLCV ---
# Leave empty for read-only public endpoints.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Exchange (live, Phase 3) — Kraken EU-licensed ---
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# --- Notifications (D-15) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Storage ---
DATABASE_URL=sqlite:///data/state/traderbot.db

# --- Observability ---
LOG_LEVEL=INFO
